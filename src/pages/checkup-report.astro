---
import Layout from "../layouts/Layout.astro";
import { CLINIC } from "../data/nav";

const REPORT_PAGE_COUNT = 27;
const REPORT_PAGES = Array.from(
  { length: REPORT_PAGE_COUNT },
  (_, i) => `/checkup-report/pages/page-${String(i + 1).padStart(2, "0")}.jpg`,
);

const REPORT_SECTIONS = [
  { title: "신체검사", desc: "체중, 체온, 맥박, 호흡수, 혈압 등 기본 활력징후를 확인합니다." },
  { title: "구강검사", desc: "육안검사와 Q-ray 형광촬영으로 치석·치은염 여부를 확인합니다." },
  { title: "피부검사", desc: "전신 피부 촉진으로 종괴, 발적 등 이상 소견을 확인합니다." },
  { title: "정형·신경검사", desc: "자세, 보행, 관절 운동 및 통증 반응을 평가합니다." },
  { title: "소변검사", desc: "요스틱 10종 검사와 현미경 침사검사를 진행합니다." },
  { title: "대변검사", desc: "기생충, 소화 상태, 잠혈 여부를 현미경으로 확인합니다." },
  { title: "안과검사", desc: "육안검사, 눈물량(STT), 안압(IOP)을 정밀 측정합니다." },
  { title: "심장사상충검사", desc: "성충항원검사와 자충검사를 함께 진행합니다." },
  { title: "혈액검사", desc: "혈구검사(CBC), 혈청화학, 전해질 등 30여 개 항목을 확인합니다." },
  { title: "방사선검사", desc: "흉부, 복부, 사지, 두부 등 부위별로 촬영·판독합니다." },
  { title: "초음파검사", desc: "복부 장기 및 심장초음파(에코)로 정밀 검사합니다." },
  { title: "종합평가", desc: "모든 소견을 바탕으로 위험도별 권고사항을 정리합니다." },
];

const FINDINGS = [
  {
    dept: "치과",
    title: "치태 및 치석",
    risk: "중간",
    advice: "치아관리 및 스케일링 권장",
  },
  {
    dept: "소화기",
    title: "담낭점액종 Type 2",
    risk: "낮음",
    advice: "식이관리 및 약복용 시도 고려, 매년 초음파 추적검사 권장",
  },
  {
    dept: "비뇨기",
    title: "방광 내 찌꺼기(Sludge)",
    risk: "낮음",
    advice: "식이관리 및 약복용 시도 고려, 매년 초음파 추적검사 권장",
  },
  {
    dept: "안과",
    title: "첩모난생",
    risk: "낮음",
    advice: "유루증이나 과도한 눈꼽 발생 시 치료",
  },
  {
    dept: "피부과",
    title: "눈 및 지간부 발적",
    risk: "낮음",
    advice: "추가 증상 발생 여부 확인",
  },
];
---

<Layout title="건강검진 결과서" description="여의도 동물병원만의 건강검진 결과서 예시를 확인하세요">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Health Report</span>
      <h1>건강검진 결과서</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <a class="crumb" href="/specialty/checkup">← 건강검진으로 돌아가기</a>

      <div class="section-head">
        <span class="eyebrow">Sample Report</span>
        <h2>실제 검진결과서 예시</h2>
        <p>여의도 동물병원에서 실제로 발급된 건강검진 결과서입니다. 개인정보는 보호자님 동의 하에 예시로 제공됩니다.</p>
      </div>

      <div class="sample-panel">
        <a
          class="sample-panel__preview"
          href={REPORT_PAGES[0]}
          data-lightbox={JSON.stringify(REPORT_PAGES)}
          data-lightbox-alt="강아지 건강검진 결과서"
          data-lightbox-zoom="true"
        >
          <img src="/checkup-report/sample-cover.jpg" alt="강아지 건강검진 결과서 표지 예시" loading="lazy" />
          <span class="sample-panel__preview-badge">총 {REPORT_PAGE_COUNT}페이지</span>
        </a>

        <div class="sample-panel__info">
          <span class="patient-card__tag">PATIENT INFO</span>
          <div class="patient-card__grid">
            <div>
              <span>수검자</span>
              <strong>꽁냥 (Poodle)</strong>
            </div>
            <div>
              <span>나이</span>
              <strong>11y 2m</strong>
            </div>
            <div>
              <span>성별</span>
              <strong>S. Female</strong>
            </div>
            <div>
              <span>검진일</span>
              <strong>2026.07.13</strong>
            </div>
          </div>
          <p class="sample-panel__desc">
            신체검사부터 구강, 피부, 소변·대변, 안과, 심장사상충, 혈액, 방사선, 초음파(복부·심장초음파)까지 전
            항목의 검사 사진과 수치, 담당수의사의 평가소견이 담긴 결과서입니다.
          </p>
          <a
            class="btn btn--primary sample-panel__cta"
            href={REPORT_PAGES[0]}
            data-lightbox={JSON.stringify(REPORT_PAGES)}
            data-lightbox-alt="강아지 건강검진 결과서"
            data-lightbox-zoom="true"
          >
            결과서 예시 전체 보기
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What's Inside</span>
        <h2>결과서에 담기는 항목</h2>
        <p>검진 프로그램의 전 항목이 사진과 수치, 수의사 소견으로 정리되어 결과서에 담깁니다.</p>
      </div>

      <div class="category-grid">
        {REPORT_SECTIONS.map((s, i) => (
          <div class="category-card">
            <span class="category-card__num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Example · 종합평가</span>
        <h2>결과 설명으로 이어지는 종합평가</h2>
        <p>검진에서 끝나지 않고, 위험도와 권고사항까지 정리해 담당수의사가 직접 설명해드립니다.</p>
      </div>

      <div class="verdict-list">
        {FINDINGS.map((f, i) => (
          <div class="verdict-item">
            <span class="verdict-item__num">{i + 1}</span>
            <div class="verdict-item__body">
              <div class="verdict-item__head">
                <span class="verdict-item__dept">{f.dept}</span>
                <span class:list={["verdict-item__risk", `is-${f.risk === "중간" ? "mid" : "low"}`]}>
                  위험도: {f.risk}
                </span>
              </div>
              <h3>{f.title}</h3>
              <p>{f.advice}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>우리 아이만의 결과서를 받아보세요</h2>
        <p>건강검진 프로그램은 예약제로 운영됩니다. 전화로 문의해 주세요.</p>
        <a class="btn btn--primary" href={`tel:${CLINIC.phone}`}>{CLINIC.phone} 전화하기</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .crumb {
    display: inline-block;
    margin-bottom: 28px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink-muted);
  }

  .crumb:hover {
    color: var(--navy-800);
  }

  .sample-panel {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 40px;
    align-items: center;
  }

  .sample-panel__preview {
    position: relative;
    display: block;
    aspect-ratio: 1241 / 1754;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease;
  }

  .sample-panel__preview:hover {
    transform: translateY(-3px);
  }

  .sample-panel__preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sample-panel__preview-badge {
    position: absolute;
    left: 14px;
    bottom: 14px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(10, 26, 48, 0.82);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .sample-panel__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 32px 36px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .patient-card__tag {
    display: inline-block;
    width: fit-content;
    padding: 5px 12px;
    border-radius: 4px;
    background: var(--navy-900);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .patient-card__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 24px;
    margin-top: 18px;
  }

  .patient-card__grid span {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
  }

  .patient-card__grid strong {
    display: block;
    margin-top: 4px;
    font-size: 16px;
    font-weight: 700;
    color: var(--navy-900);
  }

  .sample-panel__desc {
    margin-top: 22px;
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--ink-muted);
  }

  .sample-panel__cta {
    margin-top: 22px;
    width: fit-content;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .category-card {
    padding: 26px 22px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .category-card__num {
    display: inline-block;
    font-size: 13px;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .category-card h3 {
    font-size: 15.5px;
    font-weight: 700;
    color: var(--navy-900);
  }

  .category-card p {
    margin-top: 8px;
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .verdict-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .verdict-item {
    display: flex;
    gap: 18px;
    padding: 22px 26px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .verdict-item__num {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-soft);
    color: var(--navy-900);
    font-weight: 800;
    font-size: 14px;
  }

  .verdict-item__body {
    flex: 1;
  }

  .verdict-item__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .verdict-item__dept {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .verdict-item__risk {
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .verdict-item__risk.is-mid {
    background: #fbeee0;
    color: #b9711f;
  }

  .verdict-item__risk.is-low {
    background: #e5f3ea;
    color: #2f7d4f;
  }

  .verdict-item__body h3 {
    margin-top: 8px;
    font-size: 16.5px;
    font-weight: 700;
    color: var(--navy-900);
  }

  .verdict-item__body p {
    margin-top: 6px;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .cta-box {
    text-align: center;
    padding: 56px 24px;
    border-radius: 16px;
    background: linear-gradient(160deg, var(--navy-900), var(--navy-700));
    color: #fff;
  }

  .cta-box h2 {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
  }

  .cta-box p {
    margin-top: 12px;
    font-size: 14.5px;
    color: rgba(255, 255, 255, 0.78);
  }

  .cta-box .btn {
    margin-top: 24px;
  }

  @media (max-width: 860px) {
    .sample-panel {
      grid-template-columns: 1fr;
    }

    .sample-panel__preview {
      max-width: 340px;
      margin-inline: auto;
    }

    .category-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .verdict-item__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }

  @media (max-width: 560px) {
    .category-grid {
      grid-template-columns: 1fr;
    }

    .patient-card__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import { CLINIC } from "../data/nav";
import { CHECKUP_CATEGORIES, CHECKUP_NOTES, CHECKUP_OPTIONS } from "../data/checkup";
---

<Layout title="특화진료" description="여의도 동물병원 강아지 건강검진, 고양이 건강검진 특화진료 안내">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Specialty</span>
      <h1>강아지 · 고양이 건강검진</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Our Difference</span>
        <h2>검진으로 끝나지 않는 건강검진</h2>
        <p>여의도 동물병원은 검진 후 여의도 동물병원만의 검진결과서를 만들어드립니다</p>
      </div>

      <div class="feature-row">
        <div class="feature-card">
          <span class="feature-card__num">01</span>
          <h3>여의도 동물병원만의 <span class="highlight">검진결과서</span></h3>
          <p>검진 데이터를 바탕으로 우리 아이만을 위한 검진결과서를 별도로 제작합니다.</p>
        </div>
        <div class="feature-card">
          <span class="feature-card__num">02</span>
          <h3>담당수의사 <span class="highlight">1시간</span> 결과 <span class="highlight">설명</span></h3>
          <p>완성된 결과서를 바탕으로 담당수의사가 보호자님과 1:1로 약 1시간 동안 상세히 설명해드립니다.</p>
        </div>
        <div class="feature-card">
          <span class="feature-card__num">03</span>
          <h3>앞으로의 <span class="highlight">관리 방법</span> 안내</h3>
          <p>진단에서 끝나지 않고, 결과에 맞춰 앞으로 우리 아이를 어떻게 관리하면 좋을지 함께 안내해드립니다.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Check List</span>
        <h2>검사항목은</h2>
        <p>강아지와 고양이의 검사항목을 확인하세요</p>
      </div>

      <div class="checkup-table-wrap">
        <table class="checkup-table">
          <thead>
            <tr>
              <th class="checkup-table__cat">구분</th>
              <th class="checkup-table__item">검사 항목</th>
              <th>강아지</th>
              <th>고양이</th>
            </tr>
          </thead>
          <tbody>
            {CHECKUP_CATEGORIES.map((cat) =>
              cat.items.map((item, i) => (
                <tr>
                  {i === 0 && (
                    <th class="checkup-table__cat" rowspan={cat.items.length}>
                      {cat.title}
                    </th>
                  )}
                  <td class="checkup-table__item">{item.name}</td>
                  <td class:list={["checkup-table__mark", { "is-off": !item.dog }]}>
                    {item.dog ? "●" : "-"}
                  </td>
                  <td class:list={["checkup-table__mark", { "is-off": !item.cat }]}>
                    {item.cat ? "●" : "-"}
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Before Checkup</span>
        <h2>검진 전 안내사항</h2>
      </div>

      <div class="note-grid">
        {CHECKUP_NOTES.map((note, i) => (
          <div class="note-card">
            <span class="note-card__num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{note.title}</h3>
            <p>{note.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Add-on</span>
        <h2>추가 옵션</h2>
        <p>자세한 사항은 검진 시작 면담 시 담당수의사와 상의해 주세요</p>
      </div>

      <div class="option-grid">
        {CHECKUP_OPTIONS.filter((opt) => !opt.breed).map((opt) => (
          <div class="option-card">
            <h3>{opt.title}</h3>
            {opt.desc && <p>{opt.desc}</p>}
          </div>
        ))}
      </div>

      {CHECKUP_OPTIONS.filter((opt) => opt.breed).map((opt) => (
        <div class="option-card option-card--wide">
          <h3>{opt.title}</h3>
          <div class="option-card__breed">
            {opt.breed!.map((b) => (
              <div class="option-card__breed-item">
                <strong>{b.species}</strong>
                <span>{b.diseases}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>건강검진 예약 문의</h2>
        <p>검진 프로그램은 예약제로 운영됩니다. 전화로 문의해 주세요.</p>
        <a class="btn btn--primary" href={`tel:${CLINIC.phone}`}>{CLINIC.phone} 전화하기</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .feature-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    padding: 32px 28px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .feature-card__num {
    display: inline-block;
    font-size: 14px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }

  .feature-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--navy-900);
    line-height: 1.4;
  }

  .feature-card h3 .highlight {
    color: var(--accent);
  }

  .feature-card p {
    margin-top: 12px;
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--ink-muted);
  }

  .checkup-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .checkup-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }

  .checkup-table th,
  .checkup-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }

  .checkup-table thead th {
    background: var(--navy-900);
    color: #fff;
    font-weight: 700;
    font-size: 13.5px;
    text-align: center;
    padding-block: 16px;
  }

  .checkup-table tbody tr:last-child td,
  .checkup-table tbody tr:last-child th {
    border-bottom: none;
  }

  .checkup-table__cat {
    width: 110px;
    text-align: center;
    font-weight: 700;
    color: var(--navy-900);
    background: var(--bg-soft);
    vertical-align: middle;
  }

  .checkup-table__item {
    color: var(--ink);
    line-height: 1.6;
  }

  .checkup-table__mark {
    width: 72px;
    text-align: center;
    color: var(--navy-700);
    font-size: 15px;
  }

  .checkup-table__mark.is-off {
    color: var(--line);
  }

  .note-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .note-card {
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .note-card__num {
    display: block;
    font-size: 13px;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .note-card h3 {
    font-size: 15.5px;
    font-weight: 700;
    color: var(--navy-900);
    line-height: 1.4;
  }

  .note-card p {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-muted);
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .option-card {
    padding: 24px 20px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #fff;
  }

  .option-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy-900);
  }

  .option-card p {
    margin-top: 8px;
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .option-card--wide {
    margin-top: 16px;
    padding: 28px 32px;
  }

  .option-card--wide h3 {
    font-size: 16px;
  }

  .option-card__breed {
    margin-top: 16px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .option-card__breed-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 8px;
    background: var(--bg-soft);
  }

  .option-card__breed-item strong {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
  }

  .option-card__breed-item span {
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  .cta-box {
    text-align: center;
    padding: 56px 24px;
    border-radius: 16px;
    background: linear-gradient(160deg, var(--navy-900), var(--navy-700));
    color: #fff;
  }

  .cta-box h2 {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
  }

  .cta-box p {
    margin-top: 12px;
    font-size: 14.5px;
    color: rgba(255, 255, 255, 0.78);
  }

  .cta-box .btn {
    margin-top: 24px;
  }

  @media (max-width: 960px) {
    .option-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 860px) {
    .feature-row,
    .note-grid,
    .option-grid,
    .option-card__breed {
      grid-template-columns: 1fr;
    }

    .checkup-table__cat {
      width: 90px;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import { CLINIC } from "../data/nav";
---

<Layout title="페이지를 찾을 수 없습니다" description="요청하신 페이지를 찾을 수 없습니다.">
  <section class="section not-found">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1>페이지를 찾을 수 없습니다</h1>
      <p>주소가 변경되었거나 삭제된 페이지입니다. 아래 버튼으로 이동해 주세요.</p>
      <div class="not-found__actions">
        <a class="btn btn--primary" href="/">홈으로 가기</a>
        <a class="btn btn--outline" href={`tel:${CLINIC.phone}`}>{CLINIC.phone} 전화하기</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding-block: 120px;
  }

  .not-found h1 {
    margin-top: 12px;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 800;
    color: var(--navy-900);
  }

  .not-found p {
    margin-top: 14px;
    font-size: 15px;
    color: var(--ink-muted);
  }

  .not-found__actions {
    margin-top: 32px;
    display: flex;
    justify-content: center;
    gap: 14px;
  }
</style>

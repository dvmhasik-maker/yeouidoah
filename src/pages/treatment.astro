---
import Layout from "../layouts/Layout.astro";
import { CLINIC } from "../data/nav";
import { DOCTORS, DAYS } from "../data/doctors";
import { DEPARTMENTS } from "../data/departments";
---

<Layout title="진료안내" description="여의도 동물병원 진료시간 및 수의사 진료 시간표">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Treatment</span>
      <h1>진료안내</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Hours</span>
        <h2>진료시간</h2>
      </div>

      <div class="hours-grid">
        <div class="hours-card">
          <p class="hours-card__label">평일 · 토요일</p>
          <p class="hours-card__value">{CLINIC.hours[0].value}</p>
          <p class="hours-card__note">점심시간 {CLINIC.hours[2].value}</p>
        </div>
        <div class="hours-card">
          <p class="hours-card__label">일요일</p>
          <p class="hours-card__value">{CLINIC.hours[1].value}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Timetable</span>
        <h2>진료 스케줄</h2>
        <p>요일별 진료 수의사 선생님을 확인하세요</p>
      </div>

      <div class="timetable-wrap">
        <table class="timetable">
          <thead>
            <tr>
              <th class="timetable__name">원장</th>
              {DAYS.map((d) => <th>{d}</th>)}
            </tr>
          </thead>
          <tbody>
            {DOCTORS.map((doc) => (
              <tr>
                <th class="timetable__name">
                  {doc.name}
                  <span>{doc.title}</span>
                </th>
                {DAYS.map((d) => {
                  const isOff = doc.offDays.includes(d);
                  return (
                    <td class:list={["timetable__cell", { "is-off": isOff }]}>
                      {isOff ? "휴진" : "●"}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Departments</span>
        <h2>진료과목</h2>
        <p>여의도 동물병원의 진료 분야를 확인하세요</p>
      </div>

      <div class="dept-grid">
        {DEPARTMENTS.map((dept) => (
          <div class="dept-card">
            <div class="dept-card__head">
              <h3>{dept.title}</h3>
              <span class="dept-card__icon">{dept.emoji}</span>
            </div>
            <ul>
              {dept.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="dept-note">이 외에도 폭넓은 분야의 진료를 세심하게 이어가고 있습니다.</p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Reservation</span>
        <h2>예약 방법</h2>
        <p>편하신 방법으로 진료를 예약해주세요</p>
      </div>

      <div class="reserve-grid">
        <a class="reserve-card" href={`tel:${CLINIC.phone}`}>
          <span class="reserve-card__badge">01</span>
          <h3>전화 예약</h3>
          <p>{CLINIC.phone}</p>
        </a>
        <a
          class="reserve-card"
          href="https://map.naver.com/p/entry/place/34490360?c=13.00,0,0,0,dh&placePath=%2Fbooking%3Ffrom%3Dmap%26fromPanelNum%3D1%26additionalHeight%3D76%26timestamp%3D202607171404%26locale%3Dko%26svcName%3Dmap_pcv5%26entry%3Dbmp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="reserve-card__badge">02</span>
          <h3>네이버 예약</h3>
          <p>네이버에서 온라인으로 간편하게 예약하세요</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hours-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .hours-card {
    text-align: center;
    padding: 40px 28px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .hours-card__label {
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .hours-card__value {
    margin-top: 14px;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--navy-900);
  }

  .hours-card__note {
    margin-top: 12px;
    font-size: 13.5px;
    color: var(--ink-muted);
  }

  .timetable-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
  }

  .timetable {
    width: 100%;
    border-collapse: collapse;
    min-width: 680px;
  }

  .timetable th,
  .timetable td {
    padding: 26px 16px;
    text-align: center;
    font-size: 16px;
    border-bottom: 1px solid var(--line);
  }

  .timetable thead th {
    background: var(--navy-900);
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    padding-block: 20px;
  }

  .timetable tbody tr:last-child th,
  .timetable tbody tr:last-child td {
    border-bottom: none;
  }

  .timetable__name {
    text-align: left !important;
    padding-left: 28px !important;
    width: 200px;
    font-weight: 700;
    font-size: 17px;
    color: var(--navy-900);
    white-space: nowrap;
  }

  .timetable thead .timetable__name {
    color: #fff;
  }

  .timetable__name span {
    display: inline-block;
    margin-left: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-muted);
  }

  .timetable__cell {
    color: var(--navy-700);
    font-size: 18px;
  }

  .timetable__cell.is-off {
    color: var(--ink-muted);
    font-size: 14px;
  }

  .dept-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .dept-card {
    padding: 32px 28px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--bg-soft);
  }

  .dept-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .dept-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #fff;
    box-shadow: var(--shadow-sm);
    font-size: 22px;
  }

  .dept-card h3 {
    font-size: 21px;
    font-weight: 800;
    color: var(--navy-900);
  }

  .dept-card ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dept-card li {
    position: relative;
    padding-left: 14px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-muted);
  }

  .dept-card li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
  }

  .dept-note {
    margin-top: 32px;
    text-align: center;
    font-size: 14px;
    color: var(--ink-muted);
  }

  .reserve-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .reserve-card {
    display: block;
    padding: 36px 32px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  a.reserve-card:hover {
    border-color: var(--navy-700);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .reserve-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--navy-900);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 18px;
  }

  .reserve-card h3 {
    font-size: 19px;
    font-weight: 800;
    color: var(--navy-900);
  }

  .reserve-card p {
    margin-top: 10px;
    font-size: 14.5px;
    color: var(--ink-muted);
  }

  @media (max-width: 860px) {
    .hours-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .dept-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .reserve-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Lightbox from "../components/Lightbox.astro";
import { CLINIC } from "../data/nav";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Skip appending " | 여의도 동물병원" — use when `title` is already the full page title (e.g. homepage). */
  titleIsFull?: boolean;
}

const {
  title,
  description = "서울 영등포구 여의도 동물병원 - 강아지·고양이 건강검진, 심장검진, 치과진료",
  ogImage = "/logo-full-navy.png",
  titleIsFull = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const pageTitle = titleIsFull ? title : `${title} | 여의도 동물병원`;

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "VeterinaryCare",
  name: CLINIC.name,
  alternateName: CLINIC.nameEn,
  image: new URL("/logo-full-navy.png", Astro.site).toString(),
  url: Astro.site?.toString(),
  telephone: CLINIC.phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: CLINIC.address,
    addressLocality: "서울특별시 영등포구",
    addressCountry: "KR",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: CLINIC.mapLat,
    longitude: CLINIC.mapLng,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "10:00",
      closes: "19:30",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Sunday"],
      opens: "13:00",
      closes: "18:30",
    },
  ],
  sameAs: [CLINIC.naverPlaceUrl, CLINIC.kakaoChannelUrl],
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="naver-site-verification" content="23fe0501c19b49d4f4726b641408a02959fe0918" />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={CLINIC.name} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Lightbox />
  </body>
</html>

---
import { CLINIC } from "../data/nav";
---

<footer class="site-footer">
  <div class="container footer-row">
    <div class="footer-info">
      <p>{CLINIC.address}</p>
      <p>{CLINIC.phone}</p>
      <p class="footer-copyright">&copy; {new Date().getFullYear()} {CLINIC.nameEn}. All rights reserved.</p>
    </div>

    <img src="/logo-full-white.png" alt={`${CLINIC.name} ${CLINIC.nameEn}`} class="footer-logo" />
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-900);
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding-block: 40px;
  }

  .footer-info {
    font-size: 14px;
    line-height: 1.9;
  }

  .footer-copyright {
    margin-top: 6px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-logo {
    height: 68px;
    width: auto;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .footer-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      padding-block: 32px;
    }

    .footer-logo {
      height: 48px;
    }
  }
</style>
